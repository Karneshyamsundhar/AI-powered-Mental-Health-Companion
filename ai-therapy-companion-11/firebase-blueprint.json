{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "settings": {
          "type": "object",
          "properties": {
            "darkMode": { "type": "boolean" },
            "notifications": { "type": "boolean" }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Mood": {
      "title": "Mood Entry",
      "description": "Daily mood log entry",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "mood": { "type": "string", "enum": ["happy", "calm", "neutral", "anxious", "sad", "angry"] },
        "intensity": { "type": "number" },
        "note": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "mood", "timestamp"]
    },
    "Journal": {
      "title": "Journal Entry",
      "description": "Personal journal entry with AI insights",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "mood": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "aiInsights": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "content", "timestamp"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A single message in a chat session",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "image": { "type": "string", "description": "Base64 encoded image or URL" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content", "timestamp"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "A conversation session with the AI therapist",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/moods/{moodId}": {
      "schema": "Mood",
      "description": "Mood tracking entries"
    },
    "/journals/{journalId}": {
      "schema": "Journal",
      "description": "Journal entries"
    },
    "/chatSessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "Chat sessions"
    },
    "/chatSessions/{sessionId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages within a chat session"
    }
  }
}
